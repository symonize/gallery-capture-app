# Server-side secrets for the Netlify Functions. These are NOT VITE_-prefixed,
# so they never reach the client bundle. Set the same vars in the Netlify
# dashboard (Site settings -> Environment variables) for production.
#
# For local dev with `netlify dev`, copy this to .env and fill it in.

# Shared password the app prompts for (Settings) and sends with every /api call.
APP_PASSWORD=

# Third-party API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Optional overrides (defaults shown)
# CLAUDE_MODEL=claude-sonnet-4-6
# ARTISTS_TABLE=Artists
# COLLECTIONS_TABLE=Collections
# ARTWORKS_TABLE=Artworks
# ARTWORKS_IMAGE_FIELD=image
